config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Decked"
run/main_scene="uid://c5q6cdn1icd1h"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

GameManager="*res://Decked/Scenes/Game/game_manager.tscn"
BlackFade="*res://Decked/Scenes/Game/Transitions/black_fade.tscn"
